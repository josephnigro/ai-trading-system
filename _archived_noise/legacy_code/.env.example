# Alpha Vantage API Configuration
# Get a free API key at: https://www.alphavantage.co/

ALPHA_VANTAGE_API_KEY=your_free_api_key_here

# Alpaca API Configuration (for broker integration)
# Get free API credentials at: https://app.alpaca.markets
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_API_SECRET=your_alpaca_api_secret_here

# Notification transport configuration (Phase 3)

# SMTP email digest
NOTIFY_SMTP_ENABLED=false
NOTIFY_SMTP_HOST=smtp.gmail.com
NOTIFY_SMTP_PORT=587
NOTIFY_SMTP_USERNAME=your_smtp_username
NOTIFY_SMTP_PASSWORD=your_smtp_app_password
NOTIFY_SMTP_USE_TLS=true
NOTIFY_EMAIL_FROM=sender@example.com
NOTIFY_EMAIL_TO=recipient@example.com

# Twilio SMS digest (optional)
NOTIFY_TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15551234567
NOTIFY_SMS_TO=+15557654321

# Response ingestion path (drop response .txt/.json files here)
# Default runtime inbox: logs/notifications/inbox

# Dashboard URL included in daily digest emails
DASHBOARD_URL=http://localhost:8501
