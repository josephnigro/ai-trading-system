# Copy this file to .env and fill in your real values.
# NEVER commit the actual .env file — it is blocked by .gitignore.

# ── Polygon.io ────────────────────────────────────────────────────────────────
POLYGON_API_KEY=your_polygon_api_key_here

# ── Alpaca ────────────────────────────────────────────────────────────────────
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_API_SECRET=your_alpaca_api_secret_here
ALPACA_PAPER=true

# ── SMTP Email Notifications ──────────────────────────────────────────────────
NOTIFY_SMTP_ENABLED=true
NOTIFY_SMTP_HOST=smtp.gmail.com
NOTIFY_SMTP_PORT=587
NOTIFY_SMTP_USERNAME=your_email@gmail.com
NOTIFY_SMTP_PASSWORD=your_gmail_app_password_here
NOTIFY_SMTP_USE_TLS=true
NOTIFY_EMAIL_FROM=your_email@gmail.com
NOTIFY_EMAIL_TO=your_destination_email@gmail.com

# ── Automation Controls ───────────────────────────────────────────────────────
AUTO_APPROVE_PAPER=true
KILL_SWITCH=false
MAX_TRADES_PER_DAY=5
